{
  "name": "ccs",
  "version": "1.0.0",
  "description": "CLI sync tool for MCP, Skills, and Prompts across AI clients (Claude, Codex, Gemini, OpenCode)",
  "type": "module",
  "bin": {
    "ccs": "./ccs.ts"
  },
  "scripts": {
    "dev": "bun run ccs.ts",
    "build": "bun build ccs.ts --compile --outfile dist/ccs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0"
  }
}
